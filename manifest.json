{
  "id": "./",
  "name": "RPN — Plateforme communautaire",
  "short_name": "RPN",
  "description": "Articles, agenda de rendez-vous entre membres, avis et discussions — la communauté RPN dans une appli.",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "orientation": "portrait",
  "background_color": "#14110f",
  "theme_color": "#14110f",
  "lang": "fr",
  "dir": "ltr",
  "categories": ["social", "lifestyle", "education"],
  "prefer_related_applications": false,
  "related_applications": [],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "icons": [
    { "src": "icon-192.png?v=1", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "icon-512.png?v=1", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "icon-192.png?v=1", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "icon-512.png?v=1", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "screenshots": [
    { "src": "screenshot-narrow.png", "sizes": "540x960", "type": "image/png", "form_factor": "narrow", "label": "RPN sur mobile" },
    { "src": "screenshot-wide.png", "sizes": "1280x720", "type": "image/png", "form_factor": "wide", "label": "RPN sur ordinateur" }
  ],
  "edge_side_panel": { "preferred_width": 480 },
  "share_target": {
    "action": "articles/new",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": { "title": "title", "text": "text", "url": "url" }
  },
  "note_taking": { "new_note_url": "articles/new" },
  "shortcuts": [
    {
      "name": "Articles",
      "short_name": "Articles",
      "description": "Lire et publier des articles",
      "url": "articles",
      "icons": [{ "src": "icon-192.png?v=1", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Mon agenda",
      "short_name": "Agenda",
      "description": "Mes créneaux et réservations",
      "url": "agenda",
      "icons": [{ "src": "icon-192.png?v=1", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Écrire un article",
      "short_name": "Écrire",
      "description": "Rédiger un nouvel article",
      "url": "articles/new",
      "icons": [{ "src": "icon-192.png?v=1", "sizes": "192x192", "type": "image/png" }]
    }
  ]
}
